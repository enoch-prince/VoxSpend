{
  "name": "voxspend",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .ts,.tsx,.vue api convex src",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,css}\" \"api/**/*.ts\" \"convex/**/*.ts\" \"*.md\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.92",
    "chart.js": "^4.4.7",
    "convex": "^1.38.0",
    "dexie": "^4.0.11",
    "groq-sdk": "^0.8.0",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vercel/node": "^5.7.13",
    "@vitejs/plugin-vue": "^5.2.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.0.0",
    "sass": "^1.87.0",
    "typescript": "~5.7.0",
    "vite": "^6.3.4",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.8"
  }
